{
  "name": "emacs-bridge",
  "version": "3.0.0",
  "description": "Bridge to Emacs via Unix Socket",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/gdanov/work/playground/emacs-gravity/packages/emacs-bridge/hooks/SessionStart",
            "statusMessage": "gravity: session start"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/gdanov/work/playground/emacs-gravity/packages/emacs-bridge/hooks/SessionEnd",
            "statusMessage": "gravity: session end"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/gdanov/work/playground/emacs-gravity/packages/emacs-bridge/hooks/Stop",
            "statusMessage": "gravity: stop"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/gdanov/work/playground/emacs-gravity/packages/emacs-bridge/hooks/UserPromptSubmit",
            "statusMessage": "gravity: prompt"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/gdanov/work/playground/emacs-gravity/packages/emacs-bridge/hooks/SubagentStart",
            "statusMessage": "gravity: agent start"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/gdanov/work/playground/emacs-gravity/packages/emacs-bridge/hooks/SubagentStop",
            "statusMessage": "gravity: agent stop"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/gdanov/work/playground/emacs-gravity/packages/emacs-bridge/hooks/Notification",
            "statusMessage": "gravity: notification"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/gdanov/work/playground/emacs-gravity/packages/emacs-bridge/hooks/PreToolUse",
            "statusMessage": "gravity: pre-tool"
          }
        ]
      },
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/gdanov/work/playground/emacs-gravity/packages/emacs-bridge/hooks/AskUserQuestionIntercept",
            "timeout": 345600,
            "statusMessage": "gravity: question"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/gdanov/work/playground/emacs-gravity/packages/emacs-bridge/hooks/PostToolUse",
            "statusMessage": "gravity: post-tool"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/gdanov/work/playground/emacs-gravity/packages/emacs-bridge/hooks/PostToolUseFailure",
            "statusMessage": "gravity: tool failure"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/gdanov/work/playground/emacs-gravity/packages/emacs-bridge/hooks/PermissionRequest",
            "timeout": 345600,
            "statusMessage": "gravity: permission"
          }
        ]
      }
    ]
  }
}
